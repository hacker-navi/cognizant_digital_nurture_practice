<?xml version="1.0" encoding="UTF-8"?>
<!--
    applicationContext.xml
    ======================
    Exercise 1 : Defines beans for BookService and BookRepository.
    Exercise 2 : Wires BookRepository into BookService via setter injection.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- =========================================================== -->
    <!-- Exercise 1 – Bean Definitions                               -->
    <!-- =========================================================== -->

    <!-- BookRepository bean -->
    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!-- BookService bean -->
    <!-- Exercise 2 – Inject bookRepository via setter (DI)          -->
    <bean id="bookService" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

</beans>
