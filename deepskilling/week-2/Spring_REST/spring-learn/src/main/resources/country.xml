<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Spring XML Configuration for Airlines Website Country Beans.

        Stores 4 country entries for the airline booking dropdown.
        Each bean maps to a Country POJO via <property> tags.

        Bean attributes:
          id    - unique identifier used to retrieve the bean via context.getBean()
          class - fully qualified class name of the bean

        Property attributes:
          name  - maps to the setter method (e.g., name="code" → setCode())
          value - the literal string value to inject
    -->

    <!-- United States -->
    <bean id="countryUS" class="com.cognizant.springlearn.Country">
        <property name="code" value="US" />
        <property name="name" value="United States" />
    </bean>

    <!-- Germany -->
    <bean id="countryDE" class="com.cognizant.springlearn.Country">
        <property name="code" value="DE" />
        <property name="name" value="Germany" />
    </bean>

    <!-- India (default country bean) -->
    <bean id="country" class="com.cognizant.springlearn.Country">
        <property name="code" value="IN" />
        <property name="name" value="India" />
    </bean>

    <!-- Japan -->
    <bean id="countryJP" class="com.cognizant.springlearn.Country">
        <property name="code" value="JP" />
        <property name="name" value="Japan" />
    </bean>

    <!--
        Country list bean — aggregates all 4 countries as a list.
        Used for iterating through countries in the REST service.
    -->
    <bean id="countryList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="countryUS" />
                <ref bean="countryDE" />
                <ref bean="country" />
                <ref bean="countryJP" />
            </list>
        </constructor-arg>
    </bean>

</beans>
